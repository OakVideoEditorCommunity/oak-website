# Backend config (APP__ prefix, double underscore as separator)
APP__DATABASE__URL=postgres://oak:oak@db/oak_website
APP__SERVER__HOST=0.0.0.0
APP__SERVER__PORT=8080
APP__GITHUB__OWNER=OakVideoEditorCommunity
APP__GITHUB__REPO=oak
APP__GITHUB__TOKEN=
APP__R2__ENDPOINT_URL=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
APP__R2__ACCESS_KEY_ID=YOUR_R2_ACCESS_KEY_ID
APP__R2__SECRET_ACCESS_KEY=YOUR_R2_SECRET_ACCESS_KEY
APP__R2__BUCKET_NAME=oak-releases
APP__R2__PUBLIC_DOMAIN=https://pub-YOUR_ACCOUNT_ID.r2.dev
APP__R2__REGION=auto
APP__ADMIN__TOKEN=change-me-in-production
APP__DOCS__HTML_DIR=/data/docs-html

# docs-builder 配置
# 要托管的文档版本（oak-docs 仓库的 git tag/branch，逗号分隔，第一个为默认版本）。
# 留空则自动构建仓库中所有 semver tag；仓库没有 tag 时只构建一个 latest 版本。
DOCS_VERSIONS=

# Frontend config
# Public API base URL: leave EMPTY so the browser calls same-origin /api/...
# through the reverse proxy (avoids CORS / mixed-content issues).
NUXT_PUBLIC_API_BASE_URL=
# Public site URL used for SEO meta tags and the sitemap.
NUXT_PUBLIC_SITE_URL=https://www.oakvideoeditor.org
NUXT_PUBLIC_CDN_DOMAIN=
